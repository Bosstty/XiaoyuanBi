# 环境配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=
DB_PORT=3306
DB_NAME=campus_platform
DB_USER=root
DB_PASSWORD=

# Redis配置
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 邮件配置
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your-qq-email@qq.com
MAIL_PASS=your-qq-smtp-auth-code
MAIL_FROM=your-qq-email@qq.com
VERIFICATION_CODE_TTL=300
VERIFICATION_CODE_COOLDOWN=60
RESET_PASSWORD_TOKEN_TTL=1800
RESET_PASSWORD_URL_BASE=http://localhost:5173/reset-password

# JWT配置
JWT_SECRET=harbin-college-campus-service-platform-jwt-secret-2024
JWT_EXPIRES_IN=7d
DEFAULT_SERVICE_SCOPE_ID=1

# 微信配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# 文件上传配置
UPLOAD_ROOT=./uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 支付配置
PAYMENT_NOTIFY_URL=http://localhost:3000/api/payment/notify

# AI 助手配置
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_GLM_MODEL=glm-4.7
ZHIPU_MAX_TOKENS=1200
ZHIPU_TEMPERATURE=1.0
ZHIPU_TOP_P=
ZHIPU_THINKING_ENABLED=false
ZHIPU_REASONING_EFFORT=max
AI_ASSISTANT_ENABLED=true
AI_ASSISTANT_MAX_HISTORY=12
AI_ASSISTANT_MAX_ITERATIONS=6
